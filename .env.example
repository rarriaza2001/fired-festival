# Don't Go Blind — environment template
# Copy to apps/api/.env and fill in values.

# --- apps/api (NestJS) ---
DATABASE_URL="file:./dev.db"
API_PORT=3001
WEB_ORIGIN="http://localhost:3000"
LOG_LEVEL="info"

# LLM provider keys (server-side). The web UI only selects anthropic vs openai.
ANTHROPIC_API_KEY="your-anthropic-api-key"
OPENAI_API_KEY="your-openai-api-key"

ATTACHMENT_STORAGE_DIR="storage/attachments"
ATTACHMENT_TTL_HOURS=24
LINK_FETCH_TIMEOUT_MS=10000
TOOL_MODE="model_only"
# BRAVE_SEARCH_API_KEY="your-brave-api-key"

OTEL_ENABLED="false"
OTEL_PROMETHEUS_PORT=9464
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="dgb-api"

# --- apps/web (Next.js) ---
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"

# Optional — max wait per LLM HTTP call (ms). Opus on heavy reviews may need 180000+.
# LLM_REQUEST_TIMEOUT_MS=180000
