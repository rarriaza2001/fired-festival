{
  "name": "dont-go-blind",
  "version": "0.1.0",
  "private": true,
  "description": "Don't Go Blind — a Decision Stress Tester: bounded skeptical review of resource-intensive decisions before you commit.",
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:api": "pnpm --filter @dgb/api start:dev",
    "dev:web": "pnpm --filter @dgb/web dev",
    "dev": "pnpm --parallel --filter @dgb/api --filter @dgb/web run dev",
    "db:migrate": "pnpm --filter @dgb/api prisma migrate dev",
    "db:generate": "pnpm --filter @dgb/api prisma generate"
  }
}
